# Copy to .env for server-mode deployments.
# Do not commit the real .env file.

CBMP_DEPLOY_MODE=server

# Public access URL used for links sent to customers, signatures, callbacks, and downloads.
CBMP_PUBLIC_BASE_URL=https://erp.example.com

# Server listen/storage.
CBMP_ADDR=0.0.0.0:8088
CBMP_DATA=/data/app.vault

# Must stay stable after go-live. Changing this key makes existing vault snapshots unreadable.
CBMP_DATA_KEY=replace-with-32-plus-random-characters

# Optional separate backup key. If empty, backup encryption falls back to CBMP_DATA_KEY.
CBMP_BACKUP_KEY=

# Built-in super administrator. The application also has a fallback admin/admin123,
# but production deployments should override it here.
CBMP_INITIAL_ADMIN_PASSWORD=replace-with-strong-admin-password

# PostgreSQL storage. Keep this DSN consistent with POSTGRES_* below.
POSTGRES_DB=cbmp
POSTGRES_USER=cbmp
POSTGRES_PASSWORD=replace-with-strong-postgres-password
CBMP_POSTGRES_DSN=postgres://cbmp:replace-with-strong-postgres-password@postgres:5432/cbmp?sslmode=disable
CBMP_POSTGRES_LOAD_FROM_DOMAIN=0

# Redis/RabbitMQ event services.
CBMP_REDIS_ADDR=redis:6379
RABBITMQ_DEFAULT_USER=cbmp
RABBITMQ_DEFAULT_PASS=replace-with-strong-rabbitmq-password
CBMP_RABBITMQ_URL=amqp://cbmp:replace-with-strong-rabbitmq-password@rabbitmq:5672/

# ClickHouse analytics health/status endpoint.
CBMP_CLICKHOUSE_HTTP_URL=http://clickhouse:8123

# MinIO is provisioned for customer deployments that wire object storage in adapters.
MINIO_ROOT_USER=cbmpadmin
MINIO_ROOT_PASSWORD=replace-with-strong-minio-password

# Operational security.
CBMP_ENFORCE_IP_WHITELIST=1
CBMP_UPDATE_SIGNING_SECRET=replace-with-update-package-signing-secret
CBMP_COLLECTION_CALLBACK_SECRET=replace-with-collection-callback-secret
CBMP_COLLECTION_PROVIDER_TOKEN=
CBMP_COLLECTION_PROVIDER_SECRET=
CBMP_COLLECTION_DELIVERY_TIMEOUT_MS=5000

# Ed25519 public key(s) trusted for imported license packages.
# Must match the OperationsPlatform CBM_OPS_LICENSE_ISSUER_PRIVATE_KEY public key.
# Multiple keys may be separated by comma or semicolon during rotation.
CBMP_LICENSE_TRUSTED_PUBLIC_KEYS=ed25519:replace-with-ops-license-issuer-public-key

# Tax gateway. Leave empty until the real customer provider is available.
CBMP_TAX_GATEWAY_PROVIDER=
CBMP_TAX_GATEWAY_URL=
CBMP_TAX_GATEWAY_TOKEN=
CBMP_TAX_GATEWAY_SECRET=

# Map provider. Either configure provider+API key or an internal tile URL.
CBMP_MAP_PROVIDER=
CBMP_MAP_TILE_URL=
CBMP_MAP_API_KEY=
